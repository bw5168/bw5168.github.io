<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PRSM 選址存活診斷引擎</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',sans-serif;background:#0f172a;color:#e2e8f0;min-height:100vh;padding:20px;}
.container{max-width:680px;margin:0 auto;}
.header{text-align:center;padding:30px 0 20px;}
.badge{display:inline-block;background:#f59e0b;color:#000;padding:4px 14px;border-radius:20px;font-size:0.75rem;font-weight:bold;margin-bottom:12px;}
h1{color:#38bdf8;font-size:1.6rem;margin-bottom:6px;}
.sub{color:#94a3b8;font-size:0.9rem;}
.input-card{background:#1e293b;border-radius:12px;padding:20px;margin-bottom:16px;}
input{width:100%;padding:12px;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#fff;font-size:1rem;margin-bottom:12px;}
input:focus{outline:none;border-color:#38bdf8;}
button.main-btn{width:100%;padding:14px;background:#0ea5e9;color:#fff;border:none;border-radius:8px;font-size:1rem;cursor:pointer;font-weight:bold;}
button.main-btn:hover{background:#0284c7;}
button.main-btn:disabled{background:#334155;cursor:not-allowed;}
#risk-preview{display:none;}
.risk-banner{text-align:center;padding:32px;background:#1e293b;border-radius:12px;margin-bottom:16px;}
.risk-level-text{font-size:2rem;font-weight:bold;margin:12px 0;}
.risk-level-text.danger{color:#ef4444;}
.risk-level-text.warning{color:#f59e0b;}
.risk-level-text.safe{color:#22c55e;}
.risk-sublabel{color:#94a3b8;font-size:0.9rem;margin-bottom:20px;}
.unlock-hint{background:#1d4ed8;border-radius:10px;padding:14px;font-size:0.88rem;color:#bfdbfe;margin-bottom:16px;line-height:1.6;}
.unlock-btn{width:100%;padding:14px;background:#f59e0b;color:#000;border:none;border-radius:8px;font-size:1rem;cursor:pointer;font-weight:bold;}
.unlock-btn:hover{background:#d97706;}
.modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.75);z-index:100;align-items:center;justify-content:center;}
.modal-overlay.active{display:flex;}
.modal-box{background:#1e293b;border-radius:16px;padding:28px;max-width:460px;width:90%;max-height:90vh;overflow-y:auto;}
.modal-box h2{color:#38bdf8;margin-bottom:6px;font-size:1.2rem;}
.modal-box p{color:#94a3b8;font-size:0.85rem;margin-bottom:20px;}
.modal-box label{display:block;color:#94a3b8;font-size:0.8rem;margin-bottom:4px;margin-top:12px;}
.modal-box input,.modal-box select{width:100%;padding:10px;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#fff;font-size:0.95rem;}
.modal-box select option{background:#1e293b;}
.consent{font-size:0.78rem;color:#64748b;margin-top:16px;line-height:1.5;}
.consent a{color:#38bdf8;}
.submit-btn{width:100%;padding:14px;background:#0ea5e9;color:#fff;border:none;border-radius:8px;font-size:1rem;cursor:pointer;font-weight:bold;margin-top:16px;}
.submit-btn:hover{background:#0284c7;}
#result{display:none;position:relative;}
.watermark{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-30deg);font-size:4rem;color:rgba(255,255,255,0.04);pointer-events:none;z-index:10;white-space:nowrap;font-weight:bold;user-select:none;}
.olr-display{text-align:center;padding:24px;background:#1e293b;border-radius:12px;margin-bottom:16px;}
.olr-num{font-size:3.5rem;font-weight:bold;line-height:1;}
.olr-label{color:#94a3b8;font-size:0.9rem;margin-top:4px;}
.status-badge{display:inline-block;padding:6px 18px;border-radius:20px;font-weight:bold;margin-top:10px;font-size:1rem;}
.safe{color:#22c55e;}.warning{color:#f59e0b;}.danger{color:#ef4444;}
.bg-safe{background:#052e16;color:#22c55e;}
.bg-warning{background:#431407;color:#f59e0b;}
.bg-danger{background:#450a0a;color:#ef4444;}
.card{background:#1e293b;border-radius:12px;padding:16px;margin-bottom:16px;}
.card h3{font-size:0.85rem;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
.row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #334155;}
.row:last-child{border-bottom:none;}
.row-label{color:#94a3b8;font-size:0.9rem;}
.row-value{font-weight:bold;font-size:0.95rem;}
.prescription{border-left:4px solid #f59e0b;padding-left:12px;margin-top:8px;font-size:0.9rem;color:#fbbf24;line-height:1.6;}
.stress-ok{color:#22c55e;}.stress-fail{color:#ef4444;}
.btn-row{display:flex;gap:10px;margin-top:16px;}
.btn-secondary{flex:1;padding:12px;border:none;border-radius:8px;cursor:pointer;font-size:0.9rem;font-weight:bold;}
.btn-map{background:#1d4ed8;color:#fff;}
.btn-pdf{background:#374151;color:#fff;}
.zone-tag{display:inline-block;background:#1e3a5f;color:#7dd3fc;padding:2px 10px;border-radius:10px;font-size:0.8rem;margin-left:8px;}
.district-note{font-size:0.8rem;color:#64748b;margin-top:6px;}
@media print{.input-card,.btn-row,button,.watermark{display:none!important;}.container{max-width:100%;}}
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <div class="badge">PRSM V3 · District Intelligence</div>
    <h1>&#127978; PRSM 選址存活診斷引擎</h1>
    <p class="sub">輸入地址與租金，AI 自動診斷營運風險並提供改善處方</p>
  </div>
  <div class="input-card">
    <input id="addr" type="text" placeholder="例：台北市中山區南京東路二段45號">
    <input id="rent" type="number" placeholder="月租金（元）例：50000">
    <input id="revenue" type="number" placeholder="預估月營收（元）例：300000">
    <button class="main-btn" onclick="analyze()">&#128269; 立即診斷</button>
  </div>
  <div id="risk-preview">
    <div class="risk-banner">
      <div style="color:#94a3b8;font-size:0.9rem;" id="p_district"></div>
      <div class="risk-level-text" id="p_risk_text"></div>
      <div class="risk-sublabel" id="p_risk_sub"></div>
      <div class="unlock-hint">
        &#128203; 完整報告包含：租金安全線、壓力測試、競業密度分析、生存處方箋<br>
        &#128073; 免費註冊即可查看完整報告
      </div>
      <button class="unlock-btn" onclick="openModal()">&#128275; 免費查看完整報告</button>
    </div>
  </div>
  <div id="result">
    <div class="watermark" id="wm_text">PRSM 報告</div>
    <div class="olr-display">
      <div>
        <span id="r_district" style="color:#94a3b8;font-size:0.9rem;"></span>
        <span class="zone-tag" id="r_zone"></span>
      </div>
      <div class="olr-num" id="r_olr">-</div>
      <div class="olr-label">營租比 OLR（安全門檻 &ge; <span id="r_threshold">1.3</span>）</div>
      <div class="status-badge" id="r_status"></div>
      <div class="district-note" id="r_note"></div>
    </div>
    <div class="card">
      <h3>&#128203; 生存處方箋</h3>
      <div class="row">
        <span class="row-label">建議安全租金</span>
        <span class="row-value safe" id="r_target_rent">-</span>
      </div>
      <div class="row">
        <span class="row-label">科學議價空間</span>
        <span class="row-value danger" id="r_nego">-</span>
      </div>
      <div class="row">
        <span class="row-label">損益兩平營收目標</span>
        <span class="row-value" id="r_revenue_needed">-</span>
      </div>
      <div class="row">
        <span class="row-label">營收可承受下滑空間</span>
        <span class="row-value" id="r_drop">-</span>
      </div>
      <div class="prescription" id="r_advice"></div>
    </div>
    <div class="card">
      <h3>&#9889; 壓力測試（人流降20%）</h3>
      <div class="row">
        <span class="row-label">租金上漲10% OLR</span>
        <span class="row-value" id="r_rent_up_olr">-</span>
      </div>
      <div class="row">
        <span class="row-label">人流降20% OLR</span>
        <span class="row-value" id="r_stress_olr">-</span>
      </div>
      <div class="row">
        <span class="row-label">抗壓評估</span>
        <span class="row-value" id="r_stress_warn">-</span>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn-secondary btn-map" id="mapBtn">&#128205; 查看周邊競爭熱圖</button>
      <button class="btn-secondary btn-pdf" onclick="window.print()">&#128229; 下載 PDF 報告</button>
    </div>
  </div>
</div>
<div class="modal-overlay" id="leadModal">
  <div class="modal-box">
    <h2>&#128202; 查看完整診斷報告</h2>
    <p>填寫以下資訊，立即免費解鎖完整報告（含租金安全線、壓力測試、競業分析）</p>
    <label>姓名 *</label>
    <input id="f_name" type="text" placeholder="您的姓名">
    <label>手機 *</label>
    <input id="f_phone" type="tel" placeholder="0912-345-678">
    <label>Email *</label>
    <input id="f_email" type="email" placeholder="your@email.com">
    <label>您的身份</label>
    <select id="f_role">
      <option value="">請選擇</option>
      <option value="加盟主">連鎖品牌加盟主</option>
      <option value="自行創業">自行創業/開店</option>
      <option value="銀行信貸">銀行信貸人員</option>
      <option value="房仲商仲">房仲/商仲業者</option>
      <option value="投資人">投資人</option>
      <option value="其他">其他</option>
    </select>
    <label>預計投資金額</label>
    <select id="f_budget">
      <option value="">請選擇</option>
      <option value="50以下">50 萬以下</option>
      <option value="50-150">50－150 萬</option>
      <option value="150-300">150－300 萬</option>
      <option value="300以上">300 萬以上</option>
    </select>
    <label>預計開店時間</label>
    <select id="f_timeline">
      <option value="">請選擇</option>
      <option value="3個月內">3 個月內</option>
      <option value="半年內">半年內</option>
      <option value="一年內">一年內</option>
      <option value="還在評估">還在評估</option>
    </select>
    <p class="consent">提交即表示您同意本資料僅供 PRSM 選址診斷服務使用，不會提供給第三方。</p>
    <button class="submit-btn" onclick="submitLead()">&#9989; 送出並查看完整報告</button>
  </div>
</div>
<script>
var API='https://retail-survival-api-859868518848.asia-east1.run.app';
var cachedData=null;
async function analyze(){
  var addr=document.getElementById('addr').value.trim();
  if(!addr){alert('請輸入地址');return;}
  var rent=parseInt(document.getElementById('rent').value);
  var revenue=parseInt(document.getElementById('revenue').value);
  if(!rent||rent<=0){alert('請輸入月租金');return;}
  if(!revenue||revenue<=0){alert('請輸入預估月營收');return;}
  var btn=document.querySelector('.main-btn');
  btn.textContent='AI 診斷中...';
  btn.disabled=true;
  try{
    var res=await fetch(API,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address:addr,rent:rent,revenue:revenue})});
    if(!res.ok){var err=await res.json();alert('錯誤：'+(err.error||res.status));return;}
    var d=await res.json();
    cachedData=d;
    var di=d.district_intelligence;
    document.getElementById('p_district').textContent=di.district+' '+(di.commercial_type||'');
    var risk=d.analysis_result.risk_level;
    var riskEl=document.getElementById('p_risk_text');
    if(risk==='Low'){riskEl.textContent='此區域風險：低風險';riskEl.className='risk-level-text safe';document.getElementById('p_risk_sub').textContent='基本條件良好，建議查看完整報告確認細節';}
    else if(risk==='Medium'){riskEl.textContent='此區域風險：中高風險';riskEl.className='risk-level-text warning';document.getElementById('p_risk_sub').textContent='偵測到潛在風險項目，強烈建議查看完整診斷';}
    else{riskEl.textContent='此區域風險：高風險';riskEl.className='risk-level-text danger';document.getElementById('p_risk_sub').textContent='多項指標亮紅燈，進場前務必查看完整報告';}
    document.getElementById('risk-preview').style.display='block';
    document.getElementById('risk-preview').scrollIntoView({behavior:'smooth'});
  }catch(e){alert('API 連線失敗：'+e.message);}
  btn.textContent='立即診斷';
  btn.disabled=false;
}
function openModal(){document.getElementById('leadModal').classList.add('active');}
function submitLead(){
  var name=document.getElementById('f_name').value.trim();
  var phone=document.getElementById('f_phone').value.trim();
  var email=document.getElementById('f_email').value.trim();
  if(!name||!phone||!email){alert('請填寫姓名、手機、Email');return;}
  document.getElementById('wm_text').textContent=email+' · PRSM';
  document.getElementById('leadModal').classList.remove('active');
  document.getElementById('risk-preview').style.display='none';
  renderFullReport(cachedData);
}
function renderFullReport(d){
  var di=d.district_intelligence;
  document.getElementById('r_district').textContent=di.district;
  document.getElementById('r_zone').textContent=di.commercial_type||'一般商圈';
  document.getElementById('r_threshold').textContent=di.safety_threshold;
  document.getElementById('r_note').textContent=di.note||'';
  document.getElementById('r_olr').textContent=d.analysis_result.current_olr;
  var sc=d.analysis_result.risk_level==='Low'?'bg-safe':d.analysis_result.risk_level==='Medium'?'bg-warning':'bg-danger';
  var statusEl=document.getElementById('r_status');
  statusEl.className='status-badge '+sc;
  statusEl.textContent=d.analysis_result.status==='Safe'?'安全':d.analysis_result.status==='Warning'?'警戒':'危險';
  var p=d.prescription;
  document.getElementById('r_target_rent').textContent='NT$ '+Number(p.safe_rent).toLocaleString();
  document.getElementById('r_nego').textContent=p.negotiation_percent+'（NT$ '+Number(p.negotiation_margin).toLocaleString()+'）';
  document.getElementById('r_revenue_needed').textContent='NT$ '+Number(p.survival_threshold_revenue).toLocaleString();
  document.getElementById('r_drop').textContent=p.revenue_drop_allowance;
  document.getElementById('r_advice').textContent=d.recommendation;
  var st=d.stress_test;
  document.getElementById('r_rent_up_olr').textContent=st.rent_up_10_percent_olr;
  var stressEl=document.getElementById('r_stress_olr');
  stressEl.textContent=st.bad_case_olr;
  stressEl.className='row-value '+(st.bad_case_olr>=1.0?'stress-ok':'stress-fail');
  document.getElementById('r_stress_warn').textContent=st.resilience;
  document.getElementById('mapBtn').onclick=function(){window.open('https://www.google.com/maps/search/'+encodeURIComponent(document.getElementById('addr').value)+'+咖啡廳','_blank');};
  document.getElementById('result').style.display='block';
  document.getElementById('result').scrollIntoView({behavior:'smooth'});
}
</script>
</body>
</html>
